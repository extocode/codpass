# codPass bootstrap environment overrides.
#
# Primary configuration lives in app/config/config.xml (created by the web
# installer). This .env only overrides a few early bootstrap flags. Copy to
# .env to use; a missing .env is fine (safeLoad).

# Enable verbose debug output. Accepts true/false/1/0/on/off.
SYSPASS_DEBUG=false

# More bootstrap vars may be added here over time.
