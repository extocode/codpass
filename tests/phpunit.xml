<?xml version="1.0" encoding="UTF-8"?>
<phpunit backupGlobals="false" bootstrap="./SP/bootstrap.php" colors="true" processIsolation="false" stopOnFailure="false" cacheDirectory=".phpunit.cache" backupStaticProperties="false">
  <coverage>
    <report>
      <clover outputFile="./_output/coverage-clover.xml"/>
      <text outputFile="php://stdout" showUncoveredFiles="true" showOnlySummary="true"/>
    </report>
  </coverage>
  <!--
    Group convention (PHP-8 attributes on the test class or method):
      #[Group('unit')]        no DB, no DI container, pure logic (Crypt, Util, generators, ...)
      #[Group('integration')] needs a DB / DI container / filesystem fixtures
    Run a slice with (note the "no-coverage" flag, written here without a leading dash
    pair because XML comments cannot contain a double dash):
      vendor/bin/phpunit -c tests/phpunit.xml [no-coverage] [group unit]
      vendor/bin/phpunit -c tests/phpunit.xml [no-coverage] [group integration]
    The "no-coverage" flag is required locally because the <coverage> block aborts when
    no coverage driver (Xdebug/PCOV) is installed. The testsuites below still load the
    whole suite; the group filter only selects which tests within them run.
  -->
  <testsuites>
    <testsuite name="Core">
      <directory suffix="Test.php">./SP</directory>
      <exclude>./SP/Modules</exclude>
    </testsuite>
    <testsuite name="Modules">
      <directory suffix="Test.php">./SP/Modules</directory>
    </testsuite>
  </testsuites>
  <logging/>
  <source>
    <include>
      <directory suffix=".php">../lib/SP</directory>
    </include>
    <exclude>
      <directory suffix=".php">../lib/SP/DataModel</directory>
      <directory suffix=".php">../lib/SP/Providers</directory>
      <directory suffix=".php">../lib/SP/Html/Assets</directory>
      <directory suffix=".php">../lib/SP/Html/DataGrid</directory>
      <file>../lib/SP/Config/ConfigData.php</file>
    </exclude>
  </source>
</phpunit>
