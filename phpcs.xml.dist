<?xml version="1.0"?>
<ruleset name="codPass">
    <description>PSR-12 code style for codPass. Legacy code carries pre-existing
    violations; the goal is to keep new/changed code clean and reduce the debt
    over time. Run `composer cs-fix` to auto-fix your changes.</description>

    <file>lib/SP</file>
    <file>app/modules/web</file>
    <file>app/modules/api</file>

    <!-- Theme view templates are not PSR-12 PHP. -->
    <exclude-pattern>*/themes/*</exclude-pattern>
    <exclude-pattern>*.inc</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="p"/>
    <colors/>

    <rule ref="PSR12"/>
</ruleset>
